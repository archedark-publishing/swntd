{
  "name": "@swntd/shared",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server/config": {
      "types": "./src/server/config.ts",
      "default": "./src/server/config.ts"
    },
    "./server/db/schema": {
      "types": "./src/server/db/schema.ts",
      "default": "./src/server/db/schema.ts"
    },
    "./server/domain/tasks": {
      "types": "./src/server/domain/tasks.ts",
      "default": "./src/server/domain/tasks.ts"
    },
    "./server/domain/authorization": {
      "types": "./src/server/domain/authorization.ts",
      "default": "./src/server/domain/authorization.ts"
    },
    "./server/domain/fixtures": {
      "types": "./src/server/domain/fixtures.ts",
      "default": "./src/server/domain/fixtures.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
