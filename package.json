{
  "name": "swntd",
  "private": true,
  "version": "0.1.0",
  "description": "S#!% We Need To Do monorepo workspace",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @swntd/api db:generate",
    "db:migrate": "pnpm --filter @swntd/api db:migrate",
    "db:bootstrap": "pnpm --filter @swntd/api db:bootstrap",
    "jobs:run": "pnpm --filter @swntd/api jobs:run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "tsup": "^8.4.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.26.0",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  }
}
