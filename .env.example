SWNTD_AUTH_MODE=local_dev
SWNTD_TRUSTED_EMAIL_HEADER=x-forwarded-email
SWNTD_HOUSEHOLD_NAME=My Household
SWNTD_BOOTSTRAP_ADMIN_EMAILS=admin1@example.com,admin2@example.com
SWNTD_SERVICE_ACTOR_NAME=Household Assistant
SWNTD_SERVICE_ACTOR_KIND=assistant
SWNTD_DEFAULT_TIMEZONE=America/New_York
SWNTD_DONE_ARCHIVE_AFTER_DAYS=30
SWNTD_DEFAULT_CALENDAR_EXPORT_KIND=google
SWNTD_UPLOADS_DIR=./data/uploads
SWNTD_MAX_UPLOAD_BYTES=20971520
SWNTD_STALE_UPLOAD_GRACE_HOURS=24
SWNTD_DATABASE_URL=file:./data/swntd.sqlite
SWNTD_API_HOST=0.0.0.0
SWNTD_API_PORT=3001
SWNTD_API_PROXY_TARGET=http://127.0.0.1:3001
SWNTD_MCP_SERVICE_TOKEN=replace-with-issued-service-token
VITE_SWNTD_DEV_ACTOR_EMAIL=admin1@example.com
